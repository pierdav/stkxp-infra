# ─── stkxp-app (.env) ─────────────────────────────────────────────────────────
PORT=3003
NODE_ENV=production
CONSOLE_LOGS=false

# LLM Provider (anthropic | openai | google)
LLM_PROVIDER=anthropic
LLM_MODEL=claude-haiku-4-5
LLM_TEMPERATURE=0
LLM_STREAMING=true

TOOL_EXECUTOR_PROVIDER=anthropic
TOOL_EXECUTOR_MODEL=claude-haiku-4-5
TOOL_EXECUTOR_TEMPERATURE=0

RESPONSE_GENERATOR_PROVIDER=anthropic
RESPONSE_GENERATOR_MODEL=claude-sonnet-4-5

# Keys (fill in)
ANTHROPIC_API_KEY=
OPENAI_API_KEY=
GOOGLE_API_KEY=

# Elasticsearch
ELASTICSEARCH_URL=
ELASTICSEARCH_API_KEY=
# or
ELASTICSEARCH_USERNAME=
ELASTICSEARCH_PASSWORD=

# MCP
MCP_URL=https://127.0.0.1:3001/mcp

# JWT
JWT_SECRET=

# ─── stkxp-mcp-server (.env) ──────────────────────────────────────────────────
# MCP_PORT=3001
MCP_REQUEST_TIMEOUT=30000
CACHE_TTL=300000

# Elasticsearch (same instance or different)
# ELASTICSEARCH_URL=
# ELASTICSEARCH_USERNAME=
# ELASTICSEARCH_PASSWORD=

# ─── stkxp-api (.env) ─────────────────────────────────────────────────────────
# PORT=4000
# NODE_ENV=production
# ROUTE_MODE=hybrid
# ELASTICSEARCH_URL=
# ELASTICSEARCH_USERNAME=
# ELASTICSEARCH_PASSWORD=
# RATE_LIMIT_WINDOW_MS=900000
# RATE_LIMIT_MAX_REQUESTS=50000
